{
  "name": "sol_pro",
  "version": "0.2.0",
  "description": "ChatGPT Pro escalation through Codex's built-in in-app Browser.",
  "keywords": [
    "agents",
    "chatgpt",
    "chatgpt-pro",
    "codex",
    "in-app-browser"
  ],
  "homepage": "https://github.com/Lv-0/sol-pro#readme",
  "bugs": {
    "url": "https://github.com/Lv-0/sol-pro/issues"
  },
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lv-0/sol-pro.git"
  },
  "bin": {
    "sol-pro": "dist/bin/sol-pro-cli.js"
  },
  "files": [
    "dist/bin/sol-pro-cli.js",
    "dist/scripts/run-cli.js",
    "dist/src/sol-pro/session.js",
    "dist/src/sol-pro/toon.js",
    "dist/src/sol-pro/zip.js",
    "dist/src/version.js",
    "scripts/refresh-local-plugin.mjs",
    "scripts/refresh-local-plugin.ps1",
    ".codex-plugin/plugin.json",
    "assets/sol-pro_logo.png",
    "skills/sol-pro/SKILL.md",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "dist/bin/sol-pro-cli.js",
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsgo -p tsconfig.build.json",
    "start": "pnpm run build && node ./dist/scripts/run-cli.js",
    "sol-pro": "pnpm start",
    "check": "pnpm run format:check && pnpm run lint",
    "typecheck": "tsgo --noEmit",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "format:diff": "oxfmt --write . && git --no-pager diff",
    "lint": "pnpm run typecheck && oxlint",
    "lint:fix": "oxlint --fix && pnpm run format",
    "plugin:refresh": "pnpm run build && node scripts/refresh-local-plugin.mjs",
    "test": "pnpm run test:sol-pro",
    "test:sol-pro": "vitest run tests/sol-pro",
    "test:coverage": "vitest run --coverage",
    "prepare": "pnpm run build"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "fast-glob": "^3.3.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260427.1",
    "@vitest/coverage-v8": "4.1.5",
    "esbuild": "^0.28.0",
    "oxfmt": "0.47.0",
    "oxlint": "^1.62.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "devEngines": {
    "runtime": [
      {
        "name": "node",
        "version": ">=24"
      }
    ]
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
